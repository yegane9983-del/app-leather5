<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:layoutDirection="rtl"
    android:textDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="30dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_gradient"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="22dp"
            android:paddingEnd="20dp"
            android:paddingBottom="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_header_chip"
                    android:text="داشبورد تولید"
                    android:textColor="@color/text_on_primary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/recordsButton"
                    style="@style/ButtonGhost"
                    android:layout_width="150dp"
                    android:text="گزارش ماهانه  ←" />
            </LinearLayout>

            <TextView
                style="@style/TextDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="محاسبه‌گر چرم" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:lineSpacingExtra="4dp"
                android:text="کنترل دقیق مصرف، ارزیابی کیفیت برش و گزارش‌گیری حرفه‌ای از تولید."
                android:textColor="@color/white_72"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="19dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="74dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_metric_tile_dark"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:id="@+id/dashboardProductCountTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="۰"
                        android:textColor="@color/text_on_primary"
                        android:textSize="25sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="محصول ثبت‌شده"
                        android:textColor="@color/white_72"
                        android:textSize="12sp" />
                </LinearLayout>

                <View
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="74dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_metric_tile_dark"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:id="@+id/dashboardRecordCountTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="۰"
                        android:textColor="@color/text_on_primary"
                        android:textSize="25sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="محاسبه ذخیره‌شده"
                        android:textColor="@color/white_72"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="17dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_step_chip"
                    android:text="۰۱"
                    android:textColor="@color/accent_dark"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    style="@style/TextSectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="محاسبه سریع" />
            </LinearLayout>

            <TextView
                style="@style/TextCaption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:lineSpacingExtra="2dp"
                android:text="ماه و محصول را انتخاب کنید؛ نتیجه به‌صورت خودکار در گزارش‌ها ذخیره می‌شود." />

            <TextView
                style="@style/TextLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="ماه گزارش" />

            <Spinner
                android:id="@+id/monthSpinner"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/bg_input"
                android:popupBackground="@drawable/bg_dropdown" />

            <TextView
                style="@style/TextLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="جستجو و انتخاب محصول" />

            <AutoCompleteTextView
                android:id="@+id/productSearchEditText"
                style="@style/InputField"
                android:layout_marginTop="7dp"
                android:completionThreshold="1"
                android:dropDownVerticalOffset="6dp"
                android:hint="نام محصول را تایپ کنید"
                android:inputType="text"
                android:popupBackground="@drawable/bg_dropdown" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="تعداد تولید" />

                    <EditText
                        android:id="@+id/quantityEditText"
                        style="@style/InputField"
                        android:layout_marginTop="7dp"
                        android:hint="مثال: ۴۰"
                        android:inputType="numberDecimal" />
                </LinearLayout>

                <View
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/TextLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="مصرف واقعی (پا)" />

                    <EditText
                        android:id="@+id/actualLeatherEditText"
                        style="@style/InputField"
                        android:layout_marginTop="7dp"
                        android:hint="مثال: ۱۸۰"
                        android:inputType="numberDecimal" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/calculateButton"
                style="@style/ButtonPrimary"
                android:layout_width="match_parent"
                android:layout_marginTop="20dp"
                android:text="محاسبه و ثبت نتیجه" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_total_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="17dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="نتیجه آخرین محاسبه"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/resultStatusTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="برش خوب"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <TextView
                android:id="@+id/resultDifferenceTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="۰ پا"
                android:textColor="@color/text_primary"
                android:textSize="31sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/resultProductTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="ماه • محصول"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_metric_tile"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <TextView
                        android:id="@+id/resultExpectedTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="۰ پا"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="استاندارد کل"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <View
                    android:layout_width="10dp"
                    android:layout_height="1dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="72dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_metric_tile"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <TextView
                        android:id="@+id/resultActualTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="۰ پا"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="مصرف واقعی"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/resultTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_status_note"
                android:lineSpacingExtra="3dp"
                android:padding="12dp"
                android:textColor="@color/info_dark"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="17dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_step_chip"
                    android:text="۰۲"
                    android:textColor="@color/accent_dark"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    style="@style/TextSectionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:text="کاتالوگ محصولات" />

                <TextView
                    android:id="@+id/catalogCountTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_count_badge"
                    android:text="۰ محصول"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                style="@style/TextCaption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="مصرف استاندارد هر محصول را ثبت کنید تا در محاسبات قابل جستجو باشد." />

            <TextView
                style="@style/TextLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="نام محصول" />

            <EditText
                android:id="@+id/productNameEditText"
                style="@style/InputField"
                android:layout_marginTop="7dp"
                android:hint="مثال: کیف اداری"
                android:inputType="text" />

            <TextView
                style="@style/TextLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="مصرف استاندارد هر عدد (پا)" />

            <EditText
                android:id="@+id/defaultUsageEditText"
                style="@style/InputField"
                android:layout_marginTop="7dp"
                android:hint="مثال: ۴.۵"
                android:inputType="numberDecimal" />

            <Button
                android:id="@+id/addProductButton"
                style="@style/ButtonSecondary"
                android:layout_width="match_parent"
                android:layout_marginTop="17dp"
                android:text="افزودن به کاتالوگ" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="21dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="محصولات ثبت‌شده"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="برای حذف، نگه دارید"
                    android:textColor="@color/text_tertiary"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/emptyProductsTextView"
                android:layout_width="match_parent"
                android:layout_height="94dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_status_note"
                android:gravity="center"
                android:padding="18dp"
                android:text="هنوز محصولی ثبت نشده است. اولین محصول را اضافه کنید."
                android:textColor="@color/info_dark"
                android:textSize="13sp"
                android:visibility="gone" />

            <ListView
                android:id="@+id/productsListView"
                android:layout_width="match_parent"
                android:layout_height="205dp"
                android:layout_marginTop="9dp"
                android:clipToPadding="false"
                android:divider="@android:color/transparent"
                android:dividerHeight="0dp"
                android:listSelector="@android:color/transparent"
                android:paddingTop="2dp"
                android:paddingBottom="2dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="17dp"
            android:layout_marginEnd="20dp"
            android:gravity="center"
            android:text="تمام محاسبات فقط روی دستگاه شما ذخیره می‌شوند."
            android:textColor="@color/text_tertiary"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
